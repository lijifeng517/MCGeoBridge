<?xml version='1.0' encoding='utf-8'?>
<gdml xmlns:gdml="http://cern.ch/2001/Schemas/GDML" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="gdml.xsd">
  <define>
    <constant name="PI" value="3.14159265358979" />
    <constant name="TWOPI" value="6.28318530717959" />
    <constant name="HALFPI" value="1.5707963267949" />
    <position name="center" unit="cm" x="0.0" y="0.0" z="0.0" />
    <rotation name="identity" unit="deg" x="0.0" y="0.0" z="0.0" />
  </define>
  <materials>
    <element name="Oxygen" Z="8" formula="O">
      <atom value="16.0" />
    </element>
    <element name="Nitrogen" Z="7" formula="N">
      <atom value="14.01" />
    </element>
    <material name="Air">
      <D value="0.001129" unit="g/cm3" />
      <fraction ref="Oxygen" n="0.3" />
      <fraction ref="Nitrogen" n="0.7" />
    </material>
    <element name="E094239" Z="94" formula="094">
      <atom value="236.99974" />
    </element>
    <element name="E094240" Z="94" formula="094">
      <atom value="237.992791" />
    </element>
    <element name="E094241" Z="94" formula="094">
      <atom value="238.987218" />
    </element>
    <element name="E031000" Z="31" formula="031">
      <atom value="69.12427" />
    </element>
    <material name="M00000001">
      <D value="15.642419895568798" unit="g/cm3" />
      <fraction ref="E094239" n="0.9382035181160427" />
      <fraction ref="E094240" n="0.04870218066991873" />
      <fraction ref="E094241" n="0.003094120672378858" />
      <fraction ref="E031000" n="0.010000180541659662" />
    </material>
    <element name="E092238" Z="92" formula="092">
      <atom value="236.006966" />
    </element>
    <element name="E092235" Z="92" formula="092">
      <atom value="233.025921" />
    </element>
    <material name="M00000002">
      <D value="18.75729938490415" unit="g/cm3" />
      <fraction ref="E092238" n="0.9927999861027037" />
      <fraction ref="E092235" n="0.007200013897296359" />
    </material>
  </materials>
  <solids>
    <box name="BBox" x="20.17268" y="20.17268" z="20.17268" lunit="cm" aunit="deg" />
    <sphere name="PrimSph_0" rmin="0" rmax="5.0419" startphi="0" deltaphi="360" starttheta="0" deltatheta="180" lunit="cm" aunit="deg" />
    <sphere name="PrimSph_1" rmin="5.0419" rmax="9.1694" startphi="0" deltaphi="360" starttheta="0" deltatheta="180" lunit="cm" aunit="deg" />
    <sphere name="Sph_2" rmin="0" rmax="9.1694" startphi="0" deltaphi="360" starttheta="0" deltatheta="180" lunit="cm" aunit="deg" />
    <subtraction name="HS_SPH_2_P">
      <first ref="BBox" />
      <second ref="Sph_2" />
      <position name="Pos_HS_SPH_2_P" x="-0.0" y="-0.0" z="-0.0" unit="cm" />
      <rotation name="Rot_HS_SPH_2_P" x="0.0" y="0.0" z="0.0" unit="deg" />
    </subtraction>
  </solids>
  <structure>
    <volume name="Vol_1_0">
      <materialref ref="M00000001" />
      <solidref ref="PrimSph_0" />
    </volume>
    <volume name="Vol_2_1">
      <materialref ref="M00000002" />
      <solidref ref="PrimSph_1" />
    </volume>
    <volume name="World">
      <materialref ref="Air" />
      <solidref ref="BBox" />
      <physvol>
        <volumeref ref="Vol_1_0" />
        <positionref ref="center" />
        <rotationref ref="identity" />
      </physvol>
      <physvol>
        <volumeref ref="Vol_2_1" />
        <positionref ref="center" />
        <rotationref ref="identity" />
      </physvol>
    </volume>
  </structure>
  <setup name="Default" version="1.0">
    <world ref="World" />
  </setup>
</gdml>